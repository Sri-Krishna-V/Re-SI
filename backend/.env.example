# Optional local defaults
GOOGLE_API_KEY=

# Logging
LOG_LEVEL=INFO

# OpenTelemetry (safe defaults: disabled)
OBSERVABILITY_OTEL_ENABLED=false
OTEL_SERVICE_NAME=re-si-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OBSERVABILITY_OTEL_CONSOLE=false

# Prompt-response logging controls
# NO_CONTENT -> metadata only (recommended)
# true -> include prompt/response content
# false -> disable prompt-response telemetry
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT

# Enable sink-backed prompt metadata logging by setting a destination bucket name
LOGS_BUCKET_NAME=
